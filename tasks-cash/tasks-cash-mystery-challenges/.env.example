# Challenge app — copy to .env.local and match main app JWT_SECRET

JWT_SECRET=change-me-to-a-long-random-string-in-production
AUTH_COOKIE_DOMAIN=

# Local development
NEXT_PUBLIC_MAIN_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHALLENGE_APP_URL=http://localhost:3001
NEXT_PUBLIC_MYSTERY_CHALLENGES_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000

# MongoDB — must match main Tasks.cash database for shared user data
MONGODB_URI=mongodb://127.0.0.1:27017/tasks_cash

# Production
# AUTH_COOKIE_DOMAIN=.tasks.cash
# NEXT_PUBLIC_MAIN_APP_URL=https://tasks.cash
# NEXT_PUBLIC_CHALLENGE_APP_URL=https://challenge.tasks.cash
# NEXT_PUBLIC_MYSTERY_CHALLENGES_URL=https://challenge.tasks.cash
# NEXT_PUBLIC_API_URL=https://tasks.cash/api
