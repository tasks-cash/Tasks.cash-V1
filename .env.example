# ─── App ───────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000

# ─── MongoDB ───────────────────────────────────────────
# Docker (with auth): mongodb://tasks_cash:tasks_cash_secret@localhost:27017/tasks_cash?authSource=admin
# Local/simple:       mongodb://127.0.0.1:27017/tasks_cash
MONGODB_URI=mongodb://127.0.0.1:27017/tasks_cash

# ─── Redis ─────────────────────────────────────────────
# Docker maps host 6380 → container 6379 (avoids local Redis conflicts)
REDIS_URL=redis://localhost:6380

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── Game Engine ───────────────────────────────────────
XP_PER_LEVEL=1000
COIN_MULTIPLIER=1.0
REFERRAL_BONUS_COINS=50
DAILY_BONUS_COINS=25
LEADERBOARD_CACHE_TTL=300

# ─── Notifications ─────────────────────────────────────
NOTIFICATION_RETENTION_DAYS=30

# ─── Ports ─────────────────────────────────────────────
WEB_PORT=3000
ADMIN_PORT=3001
API_PORT=4000
WORKER_PORT=4001

# ─── Next.js (client) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Tasks.cash
